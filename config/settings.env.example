GITHUB_ORG="example-code-review"
GITHUB_REPO_VISIBILITY="private"
DEFAULT_BRANCH="main"
TZ="Asia/Tokyo"

WORKDIR="/var/lib/codex-review/work"
STATE_DIR="/var/lib/codex-review/state"
RUN_DIR="/var/lib/codex-review/run"

CODEX_PROMPT="@codex review"

GITLAB_HOST="git.example.com"
GITLAB_PROTOCOL="https"
GITLAB_AUTH=""
SYNC_FROM_GITLAB=0

HIGH_RISK_DIRS="auth|payment|infra|security|iam|crypto"
LOC_WEIGHT=500
MAX_LOC_SCORE=20
DIR_WEIGHT=5

MAX_REVIEWS_PER_RUN=0
SLEEP_BETWEEN_SECONDS=2

INITIAL_BASE="origin/{branch}~1"

AUTO_SEND_LARK=0
REVIEW_WAIT_SECONDS=1800
REVIEW_POLL_INTERVAL=60
CODEX_REVIEW_AUTHOR=""
REVIEW_RANGE=incremental
DAILY_REVIEW_RANGE=yesterday
INTERVAL_REVIEW_RANGE=incremental
WEEKLY_REVIEW_RANGE=incremental
WEEKLY_REVIEW_DOW=1

LARK_WEBHOOK_URL=""
LARK_WEBHOOK_URL_DRY=""
LARK_MESSAGE_TYPE="card_v2"
REVIEW_DASHBOARD_URL=""
AUTO_BUILD_REVIEW_DASHBOARD=0
REVIEW_DASHBOARD_DAYS=30

# Optional override paths for private deployment config.
# REPOS_FILE="/etc/codex-review/repos.txt"
# LARK_USER_MAP="/etc/codex-review/lark_user_map.tsv"

# === Codex Exec（本地复核+翻译，2026-05-25 起替换 codex.leeguoo.com）===
CODEX_EXEC_BIN="codex"
CODEX_EXEC_TIMEOUT=300
CODEX_EXEC_MODEL=""
CODEX_EXEC_EXTRA_ARGS=""

# === Meegle 自动建缺陷 ===
MEEGLE_PROJECT_KEY="6a13e31e9407c20a72ed6e82"
MEEGLE_WORK_ITEM_TYPE="issue"
MEEGLE_BIN="meegle"
MEEGLE_DEFAULT_ASSIGNEE=""
MEEGLE_AUTO_CREATE=1
MEEGLE_SEVERITY_MAP="P0:1 P1:2 P2:3 P3:4 P4:5 P5:5"
