GITHUB_ORG="pwtk-code-review"
GITHUB_REPO_VISIBILITY="private"
DEFAULT_BRANCH="main"
TZ="Asia/Tokyo"

WORKDIR="/var/lib/codex-review/work"
STATE_DIR="/var/lib/codex-review/state"
RUN_DIR="/var/lib/codex-review/run"

CODEX_PROMPT="@codex review , 另外代码问题, 比如 问题来源\n 最初版本（c07f0ff - tansan）：getComments 和 getReplies 都用 PaginatedResponse.fromJson，当时两者一致。\n问题引入（3d01f8d - yunanhao，2025-12-24）：\n - 修改了 getComments，改用 CommentsListResponse.fromJson 来适配 API 实际返回的 {comments, total, hasMore} 格式\n- 但漏掉了 getReplies，没有同步修改"
CODEX_SUMMARY_API="https://codex.leeguoo.work/v1/chat/completions"
CODEX_SUMMARY_TOKEN="devtoken"
CODEX_SUMMARY_MODEL="gpt-4o-mini"

GITLAB_HOST="sg-git.pwtk.cc"
GITLAB_PROTOCOL="https"
GITLAB_AUTH="xdreamstar01@gmail.com:f6ee680c410a01feb2e3a373af2b8110f991b888"
SYNC_FROM_GITLAB=1

HIGH_RISK_DIRS="auth|payment|infra|security|iam|crypto"
LOC_WEIGHT=500
MAX_LOC_SCORE=20
DIR_WEIGHT=5

MAX_REVIEWS_PER_RUN=0
SLEEP_BETWEEN_SECONDS=2

INITIAL_BASE="origin/{branch}~1"

AUTO_SEND_LARK=0
REVIEW_WAIT_SECONDS=1800
REVIEW_POLL_INTERVAL=60
CODEX_REVIEW_AUTHOR=""
REVIEW_RANGE=incremental

LARK_WEBHOOK_URL="https://open.larksuite.com/open-apis/bot/v2/hook/4b1d36c0-cf55-402c-aab6-8477d292899b"
LARK_MESSAGE_TYPE="card_v2"
